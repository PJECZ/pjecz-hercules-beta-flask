{% extends 'layouts/app.jinja2' %}
{% import 'macros/detail.jinja2' as detail %}
{% import 'macros/modals.jinja2' as modals %}
{% import 'macros/topbar.jinja2' as topbar %}

{% block title %}Estrado{% endblock %}

{% block topbar_actions %}
    {% call topbar.page_buttons('Estrado') %}
        {% if current_user.can_admin('ESTRADOS') %}
            {{ topbar.button_previous('Estrados de ' + estrado.autoridad.clave, url_for('estrados.list_autoridad_estrados', autoridad_id=estrado.autoridad_id)) }}
        {% else %}
            {{ topbar.button_previous('Estrados', url_for('estrados.list_active')) }}
        {% endif %}
        {% if current_user.can_admin('ESTRADOS') %}
            {{ topbar.button_upload('Subir', url_for('estrados.new_for_autoridad', autoridad_id=estrado.autoridad_id)) }}
        {% elif current_user.can_insert('ESTRADOS') and current_user.autoridad_id == estrado.autoridad_id %}
            {{ topbar.button_upload('Subir', url_for('estrados.new')) }}
        {% endif %}
        {% if current_user.can_admin('ESTRADOS') or (current_user.can_edit('ESTRADOS') and estrado.autoridad_id == current_user.autoridad_id) %}
            {{ topbar.button_edit('Editar', url_for('estrados.edit', estrado_id=estrado.id)) }}
            {% if estrado.estatus == 'A' %}{{ topbar.button_delete('Eliminar', url_for('estrados.delete', estrado_id=estrado.id)) }}{% endif %}
            {% if estrado.estatus == 'B' %}{{ topbar.button_recover('Recuperar', url_for('estrados.recover', estrado_id=estrado.id)) }}{% endif %}
        {% endif %}
    {% endcall %}
{% endblock %}

{% block content %}
    {% call detail.card(estatus=estrado.estatus) %}
        {{ detail.label_value_big('Descripción', estrado.descripcion) }}
        {{ detail.label_value('Distrito', estrado.autoridad.distrito.nombre) }}
        {{ detail.label_value('Autoridad', estrado.autoridad.descripcion) }}
        {{ detail.label_value('Fecha', moment(estrado.fecha, local=True).format("DD MMM YYYY")) }}
        {% if current_user.can_admin('ESTRADOS') %}
            {{ detail.label_value_new_tab('Descargar como administrador PDF', estrado.archivo, url_for('estrados.download', url=estrado.url)) }}
        {% endif %}
        {{ detail.label_value('Creado', moment(estrado.creado).format('llll')) }}
    {% endcall %}
{% endblock %}

{% block custom_javascript %}
    {% if current_user.can_admin('ESTRADOS') %}
        {% if estrado.estatus == 'A' %}{{ modals.custom_javascript_delete('Eliminar', '¿Eliminar a ' + estrado.descripcion + '?') }}{% endif %}
        {% if estrado.estatus == 'B' %}{{ modals.custom_javascript_recover('Recuperar', '¿Recuperar a ' + estrado.descripcion + '?') }}{% endif %}
    {% endif %}
{% endblock %}
