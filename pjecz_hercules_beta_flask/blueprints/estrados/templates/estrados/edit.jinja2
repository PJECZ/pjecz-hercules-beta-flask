{% extends 'layouts/app.jinja2' %}
{% import 'macros/form.jinja2' as f with context %}
{% import 'macros/topbar.jinja2' as topbar %}

{% block title %}Editar Estrado {{ estrado.descripcion }}{% endblock %}

{% block topbar_actions %}
    {{ topbar.page('Editar Estrado ' + estrado.descripcion) }}
{% endblock %}

{% block content %}
    {% call f.card() %}
        {% set form_kwargs = {'estrado_id': estrado.id} %}
        {% call f.form_tag('estrados.edit', fid='estrado_form', **form_kwargs) %}
            {% call f.form_group(form.descripcion) %}{% endcall %}
            {% call f.form_group(form.guardar) %}{% endcall %}
        {% endcall %}
    {% endcall %}
{% endblock %}
