{% extends 'layouts/app.jinja2' %}
{% import 'macros/form.jinja2' as f with context %}
{% import 'macros/topbar.jinja2' as topbar %}

{% block title %}Editar Sentencia {{ sentencia.descripcion }}{% endblock %}

{% block topbar_actions %}
    {{ topbar.page('Editar Sentencia ' + sentencia.descripcion) }}
{% endblock %}

{% block content %}
    {% call f.card() %}
        {% set form_kwargs = {'sentencia_id': sentencia.id} %}
        {% call f.form_tag('sentencias.edit', fid='sentencia_form', **form_kwargs) %}
            {% call f.form_group(form.descripcion) %}{% endcall %}
            {% call f.form_group(form.guardar) %}{% endcall %}
        {% endcall %}
    {% endcall %}
{% endblock %}
